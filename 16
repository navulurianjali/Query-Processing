import pandas as pd

data = {
    'school_code':['s001','s001','s002','s002'],
    'name':['Ram','Sam','John','Mary'],
    'age':[12,13,14,15]
}

df = pd.DataFrame(data)

grouped = df.groupby('school_code')

for name, group in grouped:
    print("\nSchool Code:", name)
    print(group)

print("\nType of GroupBy Object:")
print(type(grouped))
