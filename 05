import pandas as pd
import matplotlib.pyplot as plt

data = {
    'Date':['2024-01-01','2024-01-02','2024-01-03',
            '2024-01-04','2024-01-05'],
    'Volume':[2000,3500,2800,4000,5000]
}

df = pd.DataFrame(data)

plt.bar(df['Date'], df['Volume'])

plt.title("Trading Volume")
plt.xlabel("Date")
plt.ylabel("Volume")
plt.show()
