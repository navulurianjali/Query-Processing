import matplotlib.pyplot as plt

x = [1,2,3,4,5]

y1 = [10,20,30,40,50]
y2 = [50,40,30,20,10]

plt.plot(x,y1,
         linewidth=2,
         color='blue',
         label='Line 1')

plt.plot(x,y2,
         linewidth=4,
         color='red',
         label='Line 2')

plt.legend()

plt.xlabel("X")
plt.ylabel("Y")
plt.title("Multiple Lines")

plt.show()
