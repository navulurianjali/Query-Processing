import pandas as pd

data = {
    'Region':['East','East','West','West'],
    'Manager':['A','A','B','B'],
    'Salesman':['John','Sam','Tom','Jerry'],
    'Sale':[5000,7000,8000,6000]
}

df = pd.DataFrame(data)

pivot = pd.pivot_table(
    df,
    values='Sale',
    index=['Region','Manager','Salesman'],
    aggfunc='sum'
)

print(pivot)
