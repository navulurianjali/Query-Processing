import pandas as pd
import numpy as np

np.random.seed(1)

df = pd.DataFrame(
    np.random.randn(10,4),
    columns=['A','B','C','D']
)

def color_value(x):
    if x < 0:
        return 'color:red'
    else:
        return 'color:black'

styled_df = df.style.map(color_value)

print(df)

